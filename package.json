{
  "name": "nozzle-mosaic-adapters-monorepo",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/nozzle/mosaic-adapters.git"
  },
  "packageManager": "pnpm@10.19.0",
  "type": "module",
  "scripts": {
    "clean": "nx run-many --target=clean --exclude=examples/**",
    "changeset": "changeset",
    "changeset:publish": "changeset publish",
    "changeset:version": "changeset version",
    "preinstall": "node -e \"if(process.env.CI == 'true') {console.info('Skipping preinstall...')} else {process.exit(1)}\" || npx -y only-allow pnpm",
    "test:ci": "pnpm run test:format && pnpm run test:manifests && pnpm run test:types:all && pnpm run test:lint:all && pnpm run test:lib:all && pnpm run test:build:all",
    "test:format": "prettier . --check",
    "test:manifests": "node ./tools/check-internal-peer-ranges.mjs",
    "test:types": "nx run-many --target=test:types",
    "test:types:all": "nx run-many --target=test:types --all",
    "test:build": "nx run-many --target=test:build",
    "test:build:all": "nx run-many --target=test:build --all",
    "test:lint": "nx affected --target=test:lint",
    "test:lint:all": "nx run-many --target=test:lint --all",
    "test:lib": "nx affected --target=test:lib",
    "test:lib:all": "nx run-many --target=test:lib --all",
    "test:e2e": "pnpm run playwright:install && nx affected --target=test:e2e",
    "test:e2e:all": "pnpm run playwright:install && nx run-many --target=test:e2e --all",
    "playwright:install": "playwright install --with-deps chromium",
    "test:pr": "nx affected --targets=test:lint,test:types,test:lib,test:build,test:e2e",
    "build": "pnpm run build:packages",
    "build:packages": "nx affected --target=build --exclude=examples/**",
    "build:all": "nx run-many --target=build --all",
    "watch": "pnpm run build:packages && nx watch --all -- pnpm run build:packages",
    "format": "prettier . --write",
    "dev": "pnpm run watch"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "catalog:",
    "@tanstack/eslint-config": "catalog:",
    "@tanstack/vite-config": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-unused-imports": "catalog:",
    "jsdom": "catalog:",
    "nx": "^22.6.1",
    "prettier": "^3.6.2",
    "rimraf": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "@nozzleio/mosaic-tanstack-table-core": "workspace:*",
      "@nozzleio/mosaic-tanstack-react-table": "workspace:*",
      "@nozzleio/react-mosaic": "workspace:*"
    }
  }
}
