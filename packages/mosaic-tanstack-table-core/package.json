{
  "name": "@nozzleio/mosaic-tanstack-table-core",
  "version": "0.10.1",
  "description": "Framework-agnostic TanStack Table glue for the Mosaic data clients: state translators and the column-filter bridge.",
  "license": "MIT",
  "type": "module",
  "main": "dist/esm/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nozzle/mosaic-adapters.git",
    "directory": "packages/mosaic-tanstack-table-core"
  },
  "homepage": "https://github.com/nozzle/mosaic-adapters/tree/main/packages/mosaic-tanstack-table-core",
  "bugs": {
    "url": "https://github.com/nozzle/mosaic-adapters/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "mosaic",
    "tanstack-table",
    "duckdb",
    "headless"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "default": "./dist/esm/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clear-build": "rimraf dist",
    "build": "vite build",
    "test:types": "tsc --noEmit",
    "test:lib": "vitest",
    "test:lint": "eslint ./src ./tests"
  },
  "dependencies": {
    "@nozzleio/mosaic-core": "workspace:*"
  },
  "peerDependencies": {
    "@tanstack/table-core": "^9.0.0-beta.34",
    "@uwdata/mosaic-core": ">=0.29.0 <1",
    "@uwdata/mosaic-sql": ">=0.29.0 <1"
  },
  "devDependencies": {
    "@nozzleio/test-support": "workspace:*",
    "@tanstack/table-core": "catalog:",
    "@uwdata/mosaic-core": "catalog:",
    "@uwdata/mosaic-sql": "catalog:",
    "eslint": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:"
  }
}
