{
  "name": "@nozzleio/mosaic-tanstack-table-core",
  "version": "0.0.0",
  "description": "Framework-agnostic core APIs for the Mosaic TanStack table adapter.",
  "license": "MIT",
  "type": "module",
  "main": "dist/esm/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/nozzle/mosaic-adapters.git",
    "directory": "packages/mosaic-tanstack-table-core"
  },
  "homepage": "https://github.com/nozzle/mosaic-adapters/tree/main/packages/mosaic-tanstack-table-core",
  "bugs": {
    "url": "https://github.com/nozzle/mosaic-adapters/issues"
  },
  "keywords": [
    "mosaic",
    "tanstack-table",
    "duckdb",
    "headless"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    },
    "./filter-registry": {
      "import": {
        "types": "./dist/esm/filter-registry.d.ts",
        "default": "./dist/esm/filter-registry.js"
      }
    },
    "./grouped": {
      "import": {
        "types": "./dist/esm/grouped/index.d.ts",
        "default": "./dist/esm/grouped/index.js"
      }
    },
    "./facet-strategies": {
      "import": {
        "types": "./dist/esm/facet-strategies.d.ts",
        "default": "./dist/esm/facet-strategies.js"
      }
    },
    "./sidecar": {
      "import": {
        "types": "./dist/esm/sidecar.d.ts",
        "default": "./dist/esm/sidecar.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "vite build",
    "test:types": "tsc --noEmit",
    "test:build": "vite build",
    "test:lib": "vitest",
    "test:lint": "eslint ./src"
  },
  "dependencies": {
    "@tanstack/store": "catalog:",
    "@tanstack/table-core": "catalog:",
    "@uwdata/mosaic-core": "catalog:",
    "@uwdata/mosaic-sql": "catalog:"
  },
  "devDependencies": {
    "eslint": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:"
  }
}
