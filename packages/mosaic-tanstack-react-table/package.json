{
  "name": "@nozzleio/mosaic-tanstack-react-table",
  "version": "0.0.0",
  "description": "React bindings for the Mosaic TanStack table adapter.",
  "license": "MIT",
  "type": "module",
  "main": "dist/esm/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/nozzle/mosaic-adapters.git",
    "directory": "packages/mosaic-tanstack-react-table"
  },
  "homepage": "https://github.com/nozzle/mosaic-adapters/tree/main/packages/mosaic-tanstack-react-table",
  "bugs": {
    "url": "https://github.com/nozzle/mosaic-adapters/issues"
  },
  "keywords": ["mosaic", "react", "tanstack-table", "filters"],
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    },
    "./helpers": {
      "import": {
        "types": "./dist/esm/helpers.d.ts",
        "default": "./dist/esm/helpers.js"
      }
    },
    "./controllers": {
      "import": {
        "types": "./dist/esm/controllers.d.ts",
        "default": "./dist/esm/controllers.js"
      }
    },
    "./debug": {
      "import": {
        "types": "./dist/esm/debug.d.ts",
        "default": "./dist/esm/debug.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ./src",
    "test:types": "pnpm run typecheck",
    "test:build": "pnpm run build",
    "test:lib": "vitest",
    "test:lint": "pnpm run lint"
  },
  "dependencies": {
    "@nozzleio/mosaic-tanstack-table-core": "workspace:*",
    "@tanstack/react-store": "catalog:",
    "@tanstack/table-core": "catalog:",
    "@uwdata/mosaic-core": "catalog:",
    "@uwdata/mosaic-sql": "catalog:",
    "@uwdata/vgplot": "catalog:",
    "@nozzleio/react-mosaic": "workspace:*"
  },
  "peerDependencies": {
    "@tanstack/react-table": ">=8.17.3",
    "react": ">=19.2.4",
    "react-dom": ">=19.2.4"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "catalog:",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:"
  }
}
