{
  "name": "@nozzleio/react-mosaic",
  "version": "0.3.2",
  "description": "React bindings for the Mosaic data clients: controlled-binding hooks over @nozzleio/mosaic-core plus vgplot interop.",
  "license": "MIT",
  "type": "module",
  "main": "dist/esm/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nozzle/mosaic-adapters.git",
    "directory": "packages/react-mosaic"
  },
  "homepage": "https://github.com/nozzle/mosaic-adapters/tree/main/packages/react-mosaic",
  "bugs": {
    "url": "https://github.com/nozzle/mosaic-adapters/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "mosaic",
    "react",
    "duckdb",
    "headless",
    "data-client"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "default": "./dist/esm/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clear-build": "rimraf dist",
    "build": "vite build",
    "test:types": "tsc --noEmit",
    "test:build": "vite build",
    "test:lib": "vitest",
    "test:lint": "eslint ./src"
  },
  "dependencies": {
    "@nozzleio/mosaic-core": "workspace:*",
    "@tanstack/react-store": "catalog:"
  },
  "peerDependencies": {
    "@uwdata/mosaic-core": ">=0.24.3 <1",
    "@uwdata/mosaic-sql": ">=0.24.3 <1",
    "react": ">=19.2.0"
  },
  "devDependencies": {
    "@duckdb/duckdb-wasm": "1.33.1-dev45.0",
    "@eslint-react/eslint-plugin": "catalog:",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@uwdata/flechette": "^2.5.0",
    "@uwdata/mosaic-core": "catalog:",
    "@uwdata/mosaic-sql": "catalog:",
    "@uwdata/vgplot": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "catalog:",
    "typescript": "catalog:"
  }
}
