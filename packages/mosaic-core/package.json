{
  "name": "@nozzleio/mosaic-core",
  "version": "0.1.0",
  "description": "Framework-agnostic reactive data clients for Mosaic coordinators.",
  "license": "MIT",
  "type": "module",
  "main": "dist/esm/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nozzle/mosaic-adapters.git",
    "directory": "packages/mosaic-core"
  },
  "homepage": "https://github.com/nozzle/mosaic-adapters/tree/main/packages/mosaic-core",
  "bugs": {
    "url": "https://github.com/nozzle/mosaic-adapters/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "mosaic",
    "duckdb",
    "headless",
    "data-client"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "default": "./dist/esm/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clear-build": "rimraf dist",
    "build": "vite build",
    "test:types": "tsc --noEmit",
    "test:build": "vite build",
    "test:lib": "vitest",
    "test:lint": "eslint ./src"
  },
  "dependencies": {
    "@tanstack/store": "catalog:"
  },
  "peerDependencies": {
    "@uwdata/mosaic-core": ">=0.24.3 <1",
    "@uwdata/mosaic-sql": ">=0.24.3 <1"
  },
  "devDependencies": {
    "@duckdb/duckdb-wasm": "1.33.1-dev45.0",
    "@uwdata/flechette": "^2.5.0",
    "@uwdata/mosaic-core": "catalog:",
    "@uwdata/mosaic-sql": "catalog:",
    "eslint": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:"
  }
}
